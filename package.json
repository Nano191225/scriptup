    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    },
    "dependencies": {
        "chalk": "^5.4.1",
        "commander": "^13.1.0",
        "ora": "^8.2.0",
        "tsdown": "^0.21.2"
    },
    "devDependencies": {
        "@types/node": "^22.13.0",
        "typescript": "^5.7.0"
    }
}
